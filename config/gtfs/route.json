            "ignore_case": true,
            "replacement": " BusPlus"
        },
        {
            "regex": "((^|\\W)(univeristy)(\\W|$))",
            "ignore_case": true,
            "replacement": "$2University$4"
        },
        {
            "regex": "university of waterloo",
            "ignore_case": true,
            "is_word": true,
            "replacement": "UW"
        }
    ],
